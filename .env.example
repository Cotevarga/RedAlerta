# --- Base de datos PostgreSQL (Neon.tech) ---
DATABASE_URL=jdbc:postgresql://ep-tu-proyecto.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_USERNAME=tu_usuario_neon
DATABASE_PASSWORD=tu_password_neon

# --- CORS (orígenes permitidos, separados por coma) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# --- JWT ---
JWT_SECRET=clave-segura-de-256-bits-para-firmar-tokens
JWT_EXPIRATION=36000000

# --- Credenciales de administrador ---
ADMIN_USERNAME=adminMuni
ADMIN_PASSWORD=Corral2026

# --- Frontend (URL de la API backend) ---
VITE_API_URL=http://localhost:8080

# --- Bot ---
BACKEND_URL=http://backend:8080
WHATSAPP_NUMBER=+56995140700
PORT=3000

# --- URL pública del backend en Render (para keep-alive automático desde Spring) ---
RENDER_URL=https://redalerta-backend.onrender.com
